FROM python:3.10-slim

# Install system dependencies required for building some python wheels (like psycopg2 or xgboost)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

COPY . .

# We don't define a CMD here because docker-compose will override it 
# for the API instance vs the Celery Worker instance.